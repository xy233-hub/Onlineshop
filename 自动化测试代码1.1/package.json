{
  "name": "shopping-system-test",
  "version": "2.0.0",
  "description": "线上购物系统自动化测试套件 - 支持新版数据库设计",
  "main": "index.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "test": "jest",
    "test:env": "jest tests/environment_verify.test.js --verbose",
    "test:login": "jest tests/login.test.js",
    "test:product": "jest tests/product_management.test.js",
    "test:intent": "jest tests/purchase_intent_management.test.js",
    "test:account": "jest tests/account.test.js",
    "test:customer": "jest tests/customer_management.test.js",
    "test:category": "jest tests/category_management.test.js",
    "test:media": "jest tests/media_management.test.js",
    "test:api": "jest tests/api --verbose",
    "test:ui": "jest tests/ui --verbose",
    "test:new": "jest tests/customer_management.test.js tests/category_management.test.js tests/product_management.test.js tests/purchase_intent_management.test.js tests/media_management.test.js --verbose",
    "test:all": "jest --coverage --verbose",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "setup:db": "node scripts/setup_database_step_by_step.js",
    "clean:db": "node scripts/clean_database.js",
    "reset:db": "npm run clean:db && npm run setup:db",
    "seed:test": "mysql -u root -p onlineshop_test < test-data/seed_data.sql",
    "start:mock:api": "node scripts/mock_api_server.js",
    "report": "open reports/test-report.html"
  },
  "keywords": ["testing", "automation", "ecommerce", "database", "jest"],
  "author": "Test Team",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.12.2",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.2.3",
    "express": "^4.18.2",
    "mysql2": "^3.15.2",
    "puppeteer": "^24.25.0",
    "supertest": "^7.1.4"
  },
  "devDependencies": {
    "jest": "^30.2.0",
    "jest-html-reporter": "^4.3.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}